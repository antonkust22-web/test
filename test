# 1. Функция авторизации в X-UI
def get_xui_session():
    session = requests.Session()
    session.post(f"{XUI_URL}/login", data={"username": XUI_USERNAME, "password": XUI_PASSWORD})
    return session

# 2. Функция создания клиента (VPN-ключа)
def create_vpn_client(user_id):
    session = get_xui_session()
    # Пример запроса добавления клиента к inbounds (зависит от версии X-UI)
    # email должен быть уникальным
    client_data = {
        "id": "1", # ID inbound'а в панели
        "settings": {
            "clients": [{
                "id": user_id, # Обычно используется UUID
                "email": f"user_{user_id}",
                "limitIp": 2,
                "totalGB": 0,
                "expiryTime": 0,
                "enable": True
            }]
        }
    }
    # URL для добавления клиента (может отличаться в разных X-UI)
    response = session.post(f"{XUI_URL}/xui/inbound/addClient", json=client_data)
    return response.json()

