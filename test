# Класс для работы с Happ API
class HappAPI:
    def __init__(self, api_url: str, api_key: str):
        self.api_url = api_url
        self.api_key = api_key
        self.headers = {
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json"
        }
    
    async def create_subscription(self, user_id: int, server_id: int, 
                                  duration_days: int) -> Dict:
        """Создать подписку в Happ"""
        async with aiohttp.ClientSession() as session:
            payload = {
                "user_id": user_id,
                "server_id": server_id,
                "duration_days": duration_days,
                "start_date": datetime.now().isoformat(),
                "end_date": (datetime.now() + timedelta(days=duration_days)).isoformat()
            }
            
            try:
                async with session.post(
                    f"{self.api_url}/api/v1/subscriptions",
                    json=payload,
                    headers=self.headers
                ) as response:
                    if response.status == 201:
                        return await response.json()
                    else:
                        logger.error(f"Happ API error: {response.status}")
                        return None
            except Exception as e:
                logger.error(f"Error connecting to Happ API: {e}")
                return None
    
    async def get_user_subscriptions(self, user_id: int) -> List[Dict]:
        """Получить подписки пользователя"""
        async with aiohttp.ClientSession() as session:
            try:
                async with session.get(
                    f"{self.api_url}/api/v1/subscriptions/user/{user_id}",
                    headers=self.headers
                ) as response:
                    if response.status == 200:
                        return await response.json()
                    return []
            except Exception as e:
                logger.error(f"Error getting subscriptions: {e}")
                return []
    
    async def get_server_status(self, server_id: int) -> Dict:
        """Получить статус сервера"""
        async with aiohttp.ClientSession() as session:
            try:
                async with session.get(
                    f"{self.api_url}/api/v1/servers/{server_id}/status",
                    headers=self.headers
                ) as response:
                    if response.status == 200:
                        return await response.json()
                    return {"status": "unknown", "load": 0}
            except Exception as e:
                logger.error(f"Error getting server status: {e}")
                return {"status": "offline", "load": 0}

