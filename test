# Обработчики callback-запросов
@dp.callback_query(lambda c: c.data.startswith("server_"))

async def process_server_selection(callback_query: types.CallbackQuery, state: FSMContext):
    """Обработка выбора сервера"""
    server_id = int(callback_query.data.split("_")[1])
    
    # Сохраняем выбранный сервер в состоянии
    await state.update_data(server_id=server_id)
    await state.set_state(SubscriptionStates.choosing_period)
    
    server_name = next(
        (s["name"] for s in Config.SERVER_LIST if s["id"] == server_id),
        f"Сервер #{server_id}"
    )
    
    await callback_query.message.edit_text(
        f"Выбран сервер: *{server_name}*\n\n"
        "📅 *Выберите период подписки:*",
        parse_mode="Markdown",
        reply_markup=get_period_keyboard()
    )
    await callback_query.answer()

@dp.callback_query(lambda c: c.data.startswith("period_"))
async def process_period_selection(callback_query: types.CallbackQuery, state: FSMContext):
    """Обработка выбора периода подписки"""
    period_days = int(callback_query.data.split("_")[1])
    
    # Получаем данные из состояния
    data = await state.get_data()
    server_id = data.get("server_id")
    
    if not server_id:
        await callback_query.answer("Ошибка: сервер не выбран")
        return
    
    server_name = next(
        (s["name"] for s in Config.SERVER_LIST if s["id"] == server_id),
        f"Сервер #{server_id}"
    )
    
    # Создаем подписку в Happ
    user_id = callback_query.from_user.id
    subscription = await happ_api.create_subscription(user_id, server_id, period_days)
    
    if subscription:
        end_date = datetime.fromisoformat(subscription["end_date"])
        
        success_text = (
            "🎉 *Подписка успешно создана!*\n\n"
            f"• Сервер: *{server_name}*\n"
            f"• Период: *{period_days} дней*\n"
            f"• Действует до: *{end_date.strftime('%d.%m.%Y')}*\n\n"
            "Для подключения используйте конфигурацию из Happ приложения."
        )
        
        # Отправляем конфигурацию
        config_text = f"""
        ⚙️ *Конфигурация для подключения:*
        
        
        server: {next(s['host'] for s in Config.SERVER_LIST if s['id'] == server_id)}
        port: {next(s['port'] for s in Config.SERVER_LIST if s['id'] == server_id)}
        username: user_{user_id}
        password: {subscription['access_token'][:8]}...
        protocol: wireguard
                
        Скачайте Happ приложение и введите эти данные.
        """
        
        await callback_query.message.edit_text(success_text, parse_mode="Markdown")
        await callback_query.message.answer(config_text, parse_mode="Markdown")
    else:
        await callback_query.message.edit_text(
            "❌ *Ошибка создания подписки*\n\n"
            "Пожалуйста, попробуйте позже или обратитесь в поддержку.",
            parse_mode="Markdown"
        )
    
    await state.clear()
    await callback_query.answer()

