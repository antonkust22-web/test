from aiogram import Bot, Dispatcher, types, F
import asyncio

API_TOKEN = '8739413711:AAHj9oc1N34Xgs-qHSjnsE5m1WZgbgcJI98'
bot = Bot(token=API_TOKEN)
dp = Dispatcher()

@dp.message(F.video)
async def get_video_id(message: types.Message):
    # Бот пришлет вам ID видео, который нужно скопировать
    await message.reply(f"ID вашего видео:\n<code>{message.video.file_id}</code>", parse_mode="HTML")
    print(f"ID получен: {message.video.file_id}")

# Хендлер ловит любые отправленные боту фотографии
@dp.message(F.photo)
async def get_photo_file_id(message: types.Message):
    # message.photo[-1] берет самое лучшее качество картинки
    photo_file_id = message.photo[-1].file_id
    
    # Бот пришлет вам готовый ID, обернутый в тег code (можно скопировать в один клик)
    await message.reply(
        f"✅ <b>File ID вашей картинки:</b>\n\n<code>{photo_file_id}</code>",
        parse_mode="HTML"
    )


async def main():
    print("Бот запущен. Отправьте ему видео файлом или кружочком...")
    await dp.start_polling(bot)

if __name__ == '__main__':
    asyncio.run(main())
