            f"  Статус: {'✅ Активна' if days_left > 0 else '❌ Истекла'}\n"
            f"  Осталось дней: {max(0, days_left)}\n"
            f"  До: {end_date.strftime('%d.%m.%Y')}\n\n"
        )
    
    await message.answer(response_text, parse_mode="Markdown")

